# =============================================================================
# go_board.pcf — Pin Constraint File for the Nandland Go Board
# FPGA: Lattice iCE40 HX1K (VQ100 package) · Clock: 25 MHz
# NOTE: LEDs and switches are ACTIVE LOW
# =============================================================================

# Clock
set_io i_clk 15

# Push Buttons (active low: pressed = 0)
set_io i_switch1 53
set_io i_switch2 51
set_io i_switch3 54
set_io i_switch4 52

# LEDs (active low: 0 = on)
set_io o_led1 56
set_io o_led2 57
set_io o_led3 59
set_io o_led4 60

# 7-Segment Display 1
set_io o_segment1_a 3
set_io o_segment1_b 4
set_io o_segment1_c 93
set_io o_segment1_d 91
set_io o_segment1_e 90
set_io o_segment1_f 1
set_io o_segment1_g 2

# 7-Segment Display 2
set_io o_segment2_a 100
set_io o_segment2_b 99
set_io o_segment2_c 97
set_io o_segment2_d 95
set_io o_segment2_e 94
set_io o_segment2_f 8
set_io o_segment2_g 96

# UART
set_io i_uart_rx 73
set_io o_uart_tx 74
