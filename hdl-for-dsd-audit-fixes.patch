diff --git a/.github/workflows/lint.yml b/.github/workflows/lint.yml
new file mode 100644
index 0000000..28d0aff
--- /dev/null
+++ b/.github/workflows/lint.yml
@@ -0,0 +1,91 @@
+# .github/workflows/lint.yml — Verilog lint & symlink integrity check
+# Runs on every push and PR. Does NOT require Nix or FPGA tools —
+# uses only iverilog for syntax checking.
+
+name: Lint & Smoke Test
+
+on:
+  push:
+    branches: [main]
+  pull_request:
+
+jobs:
+  verilog-lint:
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+
+      - name: Install Icarus Verilog
+        run: sudo apt-get update && sudo apt-get install -y iverilog
+
+      - name: Syntax-check all Verilog files
+        run: |
+          echo "=== Verilog syntax check ==="
+          ERRORS=0
+          # Check .v files
+          while IFS= read -r f; do
+            if ! iverilog -g2012 -Wall -t null "$f" 2>/dev/null; then
+              echo "FAIL: $f"
+              ERRORS=$((ERRORS + 1))
+            fi
+          done < <(find labs/ shared/lib/ -name "*.v" -not -path "*/node_modules/*")
+
+          # Check .sv files
+          while IFS= read -r f; do
+            if ! iverilog -g2012 -Wall -t null "$f" 2>/dev/null; then
+              echo "FAIL: $f"
+              ERRORS=$((ERRORS + 1))
+            fi
+          done < <(find labs/ -name "*.sv" -not -path "*/node_modules/*")
+
+          echo ""
+          if [ "$ERRORS" -gt 0 ]; then
+            echo "::error::$ERRORS file(s) failed syntax check"
+            exit 1
+          else
+            echo "All Verilog/SV files pass syntax check"
+          fi
+
+      - name: Verify symlinks resolve
+        run: |
+          echo "=== Symlink integrity ==="
+          BROKEN=0
+          while IFS= read -r link; do
+            if [ ! -e "$link" ]; then
+              echo "BROKEN: $link -> $(readlink "$link")"
+              BROKEN=$((BROKEN + 1))
+            fi
+          done < <(find . -type l)
+
+          if [ "$BROKEN" -gt 0 ]; then
+            echo "::error::$BROKEN broken symlink(s)"
+            exit 1
+          else
+            echo "All symlinks resolve"
+          fi
+
+      - name: Check PCF consistency
+        run: |
+          echo "=== PCF consistency ==="
+          CANONICAL="shared/pcf/go_board.pcf"
+          ERRORS=0
+          while IFS= read -r pcf; do
+            [ "$pcf" = "$CANONICAL" ] && continue
+            if [ -L "$pcf" ]; then
+              TARGET=$(readlink -f "$pcf")
+              EXPECTED=$(readlink -f "$CANONICAL")
+              if [ "$TARGET" != "$EXPECTED" ]; then
+                echo "WRONG TARGET: $pcf -> $(readlink "$pcf")"
+                ERRORS=$((ERRORS + 1))
+              fi
+            else
+              echo "NOT A SYMLINK: $pcf (should link to shared/pcf/go_board.pcf)"
+              ERRORS=$((ERRORS + 1))
+            fi
+          done < <(find labs/ -name "go_board.pcf")
+
+          if [ "$ERRORS" -gt 0 ]; then
+            echo "::warning::$ERRORS PCF file(s) are not symlinks to shared/pcf/go_board.pcf"
+          else
+            echo "All PCF files are consistent"
+          fi
